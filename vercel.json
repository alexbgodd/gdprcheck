{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://gdprcheck.bg; frame-ancestors 'none';"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/sigma.html",
      "destination": "/risk.html",
      "permanent": true
    },
    {
      "source": "/risk.html",
      "destination": "/risk",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/risk",
      "destination": "/risk.html"
    },
    {
      "source": "/check",
      "destination": "/check.html"
    }
  ]
}